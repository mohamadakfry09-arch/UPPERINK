# Google Apps Script Web App URL (deploy sebagai Web App dari GAS editor)
VITE_GAS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID_HERE/exec

# Admin Credentials
VITE_ADMIN_EMAIL=admin@UPPERINK.id
VITE_ADMIN_PASSWORD=Admin@2024!

# Nomor WhatsApp Admin (format: 62xxx tanpa + atau 0)
VITE_WA_ADMIN=6281234567890

# Info Perusahaan
VITE_COMPANY_NAME=UPPERINK
VITE_COMPANY_TAGLINE=Konveksi Baju Berkualitas Tinggi
VITE_COMPANY_ADDRESS=Jl. Contoh No. 123, Kota Anda

# Google Drive Folder ID untuk file desain & galeri
VITE_GDRIVE_FOLDER_ID=YOUR_FOLDER_ID_HERE
    